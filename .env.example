# ============================================================================
# TRINCHERA LIBERTARIA BOT - Variables de Entorno (VERSIÓN LIGERA SIN DB)
# ============================================================================
# Copia este archivo a .env y completa con tus valores reales.
# NUNCA subas el archivo .env real a Git.
# Sin PostgreSQL, sin Alembic, sin SQLAlchemy. Solo aiogram + xai-sdk.

# ---------------------------------------------------------------------------
# TELEGRAM (obligatorio)
# ---------------------------------------------------------------------------
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TRINCHERA_CHAT_ID=-1001234567890          # ID del grupo principal (negativo)

# ---------------------------------------------------------------------------
# XAI / GROK API (obligatorio para /pregunta y /sticker)
# ---------------------------------------------------------------------------
XAI_API_KEY=xai-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# ADMINISTRADORES (separados por coma) - SOLO ellos usan /stats y /crear_encuesta
# ---------------------------------------------------------------------------
ADMIN_USER_IDS=123456789,987654321        # Tus IDs de Telegram (sin espacios)

# Chats especiales (opcionales)
LOG_CHANNEL_ID=-100111222333              # Canal privado para logs de moderación (recomendado)

# ---------------------------------------------------------------------------
# ENTORNO
# ---------------------------------------------------------------------------
ENVIRONMENT=production                    # development | production
DEBUG=false

# ============================================================================
# INSTRUCCIONES RÁPIDAS (versión ligera sin DB)
# ============================================================================
# 1. BOT_TOKEN → @BotFather (desactivar privacy, habilitar join groups)
# 2. XAI_API_KEY → https://console.x.ai (necesaria para /pregunta y /sticker)
# 3. TRINCHERA_CHAT_ID → ID negativo del grupo (usa @userinfobot o /getid)
# 4. ADMIN_USER_IDS → tus IDs de Telegram (separados por coma)
# 5. (Opcional) LOG_CHANNEL_ID para logs de moderación
#
# Ejecutar:  uv run python -m trinchera_bot.main   (o python -m con PYTHONPATH=src)
# Sin Postgres, sin migraciones, sin docker para DB.
# ============================================================================